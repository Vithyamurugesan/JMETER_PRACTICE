          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Encrypt_Password">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import javax.crypto.Cipher
import javax.crypto.spec.SecretKeySpec
import java.util.Base64

def username=&apos;vithyamurugesan&apos;
def password=&apos;1234&apos;

def secretKey=&apos;123457890123456&apos;

def key=new SecretKeySpec(secretKey.getBytes(&apos;UTF-8&apos;),&apos;AES&apos;)
def cipher=Cipher.getInstance(&apos;AES&apos;)

cipher.init(Cipher.ENCRYPT_MODE,key)

byte[] encryptedBytes=cipher.doFinal(password.getBytes(&apos;UTF-8&apos;))
String encryptedPassword=Base64.encoder.encodeToString(encryptedBytes)

vars.put(&quot;username&quot;,username)
vars.put(&quot;encryptedPassword&quot;,encryptedPassword)

log.info(&quot;=================================&quot;)
log.info(&quot;Username               :&quot;+username)
log.info(&quot;Original Password      :&quot;+password)
log.info(&quot;Encrpted Password      :&quot;+encrpytedPassword)
log.info(&quot;==================================&quot;)
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Decrypt_Password">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import javax.crypto.Cipher
import javax.crypto.spec.SecretKeySpec
import java.util.Base64


def secretKey=&apos;123457890123456&apos;
def encryptedPassword=vars.get(&quot;encryptedPassword&quot;)


def key=new SecretKeySpec(secretKey.getBytes(&apos;UTF-8&apos;),&apos;AES&apos;)
def cipher=Cipher.getInstance(&apos;AES&apos;)

cipher.init(Cipher.ENCRYPT_MODE,key)

byte[] decryptedBytes=cipher.doFinal(Base64.decoder.decode(encryptedPassword))
String decryptedPassword=new String(decryptedBytes,&quot;UTF-8&quot;)


vars.put(&quot;decryptedPassword&quot;,decryptedPassword)

log.info(&quot;=================================&quot;)
log.info(&quot;Encrpted Password      :&quot;+encrpytedPassword)
log.info(&quot;Decrpted Password      :&quot;+DecrpytedPassword)

log.info(&quot;==================================&quot;)
</stringProp>
          </JSR223PreProcessor>
