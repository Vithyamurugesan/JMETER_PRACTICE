                  <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell PreProcessor" enabled="true">
                    <stringProp name="filename"></stringProp>
                    <stringProp name="parameters"></stringProp>
                    <boolProp name="resetInterpreter">false</boolProp>
                    <stringProp name="script">import java.util.List;

List productList = (List) vars.getObject(&quot;productList&quot;);

if (productList == null || productList.isEmpty()) {
    throw new Exception(&quot;Product list is empty&quot;);
}

String currentIndex = vars.get(&quot;currentIndex&quot;);

if (currentIndex == null) {
    currentIndex = &quot;0&quot;;
}

int index = Integer.parseInt(currentIndex);

if (index &gt;= productList.size()) {
    index = 0;
}

String productId = productList.get(index).toString();

vars.put(&quot;currentProductId&quot;, productId);
vars.put(&quot;currentIndex&quot;, String.valueOf(index + 1));

log.info(&quot;Current Index = &quot; + index);
log.info(&quot;Current Product ID = &quot; + productId);</stringProp>
                  </BeanShellPreProcessor>
