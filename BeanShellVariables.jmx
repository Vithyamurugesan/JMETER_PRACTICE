            <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="SourcePage_BeanShell_PostProcessor" enabled="true">
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="script">import java.util.regex.*;

String response = prev.getResponseDataAsString();

Pattern pattern = Pattern.compile(&quot;(.*?)name=\&quot;_sourcePage\&quot; value=\&quot;(.*?)\&quot;(.*?)Register Now!&quot;, Pattern.DOTALL);
Matcher matcher = pattern.matcher(response);

if (matcher.find()) {
    vars.put(&quot;sourcePage_g1&quot;, matcher.group(1));
    vars.put(&quot;sourcePage&quot;, matcher.group(2));      // Required value
    vars.put(&quot;sourcePage_g3&quot;, matcher.group(3));

    log.info(&quot;Source Page = &quot; + matcher.group(2));
} else {
    vars.put(&quot;sourcePage&quot;, &quot;NOT_FOUND&quot;);
    log.info(&quot;sourcePage not found.&quot;);
}</stringProp>
            </BeanShellPostProcessor>
            <hashTree/>
            <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="fp_BeanShell PostProcessor" enabled="true">
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="script">import java.util.regex.*;

String response = prev.getResponseDataAsString();

Pattern pattern = Pattern.compile(&quot;name=\&quot;__fp\&quot; value=\&quot;(.*?)\&quot;(.*?)Register Now!&quot;, Pattern.DOTALL);
Matcher matcher = pattern.matcher(response);

if (matcher.find()) {
    vars.put(&quot;fp_g1&quot;, matcher.group(1));   // __fp value
    vars.put(&quot;fp_g2&quot;, matcher.group(2));   // Remaining text
    vars.put(&quot;fp&quot;, matcher.group(1));      // Store the required value

    log.info(&quot;FP Value = &quot; + matcher.group(1));
} else {
    vars.put(&quot;fp&quot;, &quot;NOT_FOUND&quot;);
    log.info(&quot;FP value not found&quot;);
}</stringProp>
            </BeanShellPostProcessor>
