            <hashTree/>
            <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="ProductId_BeanShellPostProcessor" enabled="true">
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="script">import java.util.regex.*;
import java.util.ArrayList;
import java.util.List;

String response = prev.getResponseDataAsString();

log.info(&quot;==================================&quot;);
log.info(&quot;Sampler = &quot; + prev.getSampleLabel());
log.info(&quot;URL = &quot; + prev.getURL());

Pattern pattern = Pattern.compile(&quot;productId=(.*?)\&quot;&quot;);
Matcher matcher = pattern.matcher(response);

List productList = new ArrayList();
int count = 0;

while (matcher.find()) {
    String productId = matcher.group(1);
    productList.add(productId);
    count++;
}

vars.putObject(&quot;productList&quot;, productList);
vars.put(&quot;productCount&quot;, String.valueOf(count));

log.info(&quot;Total Product IDs Found: &quot; + count);
log.info(&quot;Product List: &quot; + productList);</stringProp>
            </BeanShellPostProcessor>
            <hashTree/>
            <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell PreProcessor" enabled="true">
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="script">import java.util.regex.Pattern;
import java.util.regex.Matcher;

String response = prev.getResponseDataAsString();

Pattern pattern = Pattern.compile(&quot;categoryId=(.*?)\&quot;&gt;&quot;);
Matcher matcher = pattern.matcher(response);

while (matcher.find()) {
    String categoryId = matcher.group(1);

    if (&quot;FISH&quot;.equals(categoryId)) {
        vars.put(&quot;selectedCategory&quot;, categoryId);
        break;
    }
}

log.info(&quot;Selected Category = &quot; + vars.get(&quot;selectedCategory&quot;));</stringProp>
            </BeanShellPreProcessor>
            <hashTree/>
          </hashTree>
          <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="BeanShell Sampler" enabled="true">
            <stringProp name="BeanShellSampler.query">import java.util.List;

List productList = (List) vars.getObject(&quot;productList&quot;);

boolean valid = true;

for (int i = 0; i &lt; productList.size(); i++) {
    String productId = productList.get(i).toString();

    if (!productId.startsWith(&quot;FI&quot;)) {
        valid = false;
        break;
    }
}

vars.put(&quot;isValidProductId&quot;, String.valueOf(valid));

log.info(&quot;All Product IDs start with FI: &quot; + valid);</stringProp>
          </BeanShellSampler>
          <hashTree/>
